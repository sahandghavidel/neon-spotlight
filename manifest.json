{
  "manifest_version": 3,
  "name": "Amazing Click Effect",
  "description": "Adds customizable neon border animations to clicked buttons and hovered page elements.",
  "version": "1.7.0",
  "action": {
    "default_title": "Amazing Click Effect",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-effect.js"],
      "run_at": "document_idle"
    }
  ]
}
